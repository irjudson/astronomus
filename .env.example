# Astronomus Configuration — copy to .env and customize

# ── Credentials ──────────────────────────────────────────────────────────────
# Database and Redis passwords (defaults work for local dev; change for any
# internet-facing deployment).
POSTGRES_PASSWORD=buffalo-jump
REDIS_PASSWORD=buffalo-jump

# ── Storage ───────────────────────────────────────────────────────────────────
# Host path to your FITS/capture files (mounted as /fits inside the container).
# Change this to wherever your Seestar S50 saves files.
SEESTAR_FITS_PATH=/mnt/seestar-s50

# ── Location defaults ─────────────────────────────────────────────────────────
DEFAULT_LAT=45.9183
DEFAULT_LON=-111.5433
DEFAULT_ELEVATION=1234
DEFAULT_TIMEZONE=America/Denver
DEFAULT_LOCATION_NAME=My Observatory

# ── API Keys (optional) ───────────────────────────────────────────────────────
# OpenWeatherMap — for weather forecasts (free tier works fine)
OPENWEATHERMAP_API_KEY=

# N2YO — for satellite pass predictions (free at n2yo.com)
N2YO_API_KEY=

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_TIMEZONE=America/Denver
